{
  "openapi": "3.0.0",
  "info": {
    "title": "Attendance System API",
    "version": "1.0.0"
  },
  "tags": [
    { "name": "Auth", "description": "Authentication" },
    { "name": "Students", "description": "Student management" },
    { "name": "Classes", "description": "Class management" },
    { "name": "Class Arms", "description": "Class arm management" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Token"
      }
    }
  },
  "paths": {
    "/Student-Attendance-System01-main/api/login.php": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "userType": { "type": "string", "example": "Administrator" }
                },
                "required": ["username", "password", "userType"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login response"
          }
        }
      }
    },
    "/Student-Attendance-System01-main/api/students.php": {
      "get": {
        "tags": ["Students"],
        "summary": "List students",
        "security": [
          { "BearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Students list"
          }
        }
      }
    },
    "/Student-Attendance-System01-main/api/add_student.php": {
      "post": {
        "tags": ["Students"],
        "summary": "Create student",
        "security": [
          { "BearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" },
                  "otherName": { "type": "string" },
                  "admissionNumber": { "type": "string" },
                  "classId": { "type": "string" },
                  "classArmId": { "type": "string" }
                },
                "required": ["firstName", "lastName", "admissionNumber", "classId", "classArmId"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Add student response"
          }
        }
      }
    },
    "/Student-Attendance-System01-main/api/classes.php": {
      "get": {
        "tags": ["Classes"],
        "summary": "List classes",
        "security": [
          { "BearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Classes list"
          }
        }
      }
    },
    "/Student-Attendance-System01-main/api/add_class.php": {
      "post": {
        "tags": ["Classes"],
        "summary": "Create class",
        "security": [
          { "BearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "className": { "type": "string" }
                },
                "required": ["className"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Add class response"
          }
        }
      }
    },
    "/Student-Attendance-System01-main/api/classarms.php": {
      "get": {
        "tags": ["Class Arms"],
        "summary": "List class arms",
        "security": [
          { "BearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Class arms list"
          }
        }
      }
    }
  }
}