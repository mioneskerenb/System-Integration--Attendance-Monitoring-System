{
  "openapi": "3.0.0",
  "info": {
    "title": "Attendance System API",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Token"
      }
    }
  },
  "paths": {
    "/Student-Attendance-System01-main/api/login.php": {
      "post": {
        "summary": "Login user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "userType": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login response"
          }
        }
      }
    },
    "/Student-Attendance-System01-main/api/students.php": {
      "get": {
        "summary": "Get students",
        "security": [
          { "BearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Students list"
          }
        }
      }
    }
  }
}